# The database is host state on a mounted volume, never baked into the
# image — see the SLOSHBOT_DB comment in the Dockerfile.
sloshbot.db*

# VCS / editor / local tooling — irrelevant at runtime
.git/
.gitignore
.claude/
.session-trace/
.DS_Store

# Local dev environment — rebuilt fresh by `uv sync` in the image
.venv/
__pycache__/
*.pyc

# Debug/scratch output regenerated by pipeline runs, not needed at runtime
out.json
err.log
*.log

# Dev/eval-only assets — not read by the running app
golden_set.csv
tags.csv

# Docs — not needed inside the image
ARCHITECTURE.md
