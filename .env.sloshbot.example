# Copy this file to .env.sloshbot (gitignored) and fill in real values.
# Sourced by scripts/run_daily.sh before the daily sync run — launchd starts
# processes with a bare environment, so this is the only place these secrets
# live on this Mac.

# Base URL of the prod host sync talks to (see sync.py). No trailing slash.
SLOSHBOT_PROD_URL=https://sloshbot.kingeryzach2002.selfhost.imbue.com

# Bearer token for the /admin/export and /admin/ingest endpoints on prod.
SLOSHBOT_ADMIN_TOKEN=changeme

# Used by the scoring step of the pipeline (scoring/scorers/booze.py).
ANTHROPIC_API_KEY=changeme
